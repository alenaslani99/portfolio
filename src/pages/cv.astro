---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    Detail-oriented software developer with hands-on experience building full-stack web applications, CRUD systems, and reporting workflows. Comfortable working across the stack with PHP, Laravel, JavaScript, Vue.js, and SQL databases. Experienced in ERP environments, authentication and authorization systems, REST API design, and collaborating with both technical and non-technical stakeholders. Actively uses AI-powered development tools to improve productivity, debugging, and delivery speed.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Department School of Information and Communication Technologies, Belgrade"
      subtitle="2021 - 2026, ICT College (https://ict.edu.rs/)"
    />
    <TimeLineElement
      title="Gymnasium - General Studies"
      subtitle="2017 - 2021, Velika Plana"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Programmer at Cmana - Krnjevo"
      subtitle="June 2025 to September 2025"
    >
      Worked on improving and automating employee time tracking and reporting processes within a complex ERP system used across multiple departments. Developed and optimized SQL Server queries to process real-time attendance data, including clock-ins, clock-outs, and break records. Built and maintained reporting workflows that delivered accurate and timely data to finance, retail, and executive management. Collaborated with stakeholders to understand reporting requirements and adjust outputs based on payroll and operational needs. Improved reporting reliability, reduced manual data handling, and increased efficiency in payroll-related workflows.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <div class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-x-20">
      <div>
        <h3 class="text-lg font-semibold mb-3">Frontend</h3>
        <div class="grid grid-cols-4 gap-4">
          <img src="/skills/html5.svg" alt="HTML5" title="HTML5" class="w-10 h-10" />
          <img src="/skills/javascript.svg" alt="JavaScript" title="JavaScript" class="w-10 h-10" />
          <img src="/skills/typescript.svg" alt="TypeScript" title="TypeScript" class="w-10 h-10" />
          <img src="/skills/vuedotjs.svg" alt="Vue.js" title="Vue.js" class="w-10 h-10" />
          <img src="/skills/jquery.svg" alt="jQuery" title="jQuery" class="w-10 h-10" />
          <img src="/skills/react.svg" alt="React" title="React" class="w-10 h-10" />
          <img src="/skills/inertia.svg" alt="Inertia.js" title="Inertia.js" class="w-10 h-10" />
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-3">UI</h3>
        <div class="grid grid-cols-4 gap-4">
          <img src="/skills/css.svg" alt="CSS3" title="CSS3" class="w-10 h-10" />
          <img src="/skills/bootstrap.svg" alt="Bootstrap" title="Bootstrap" class="w-10 h-10" />
          <img src="/skills/tailwindcss.svg" alt="Tailwind CSS" title="Tailwind CSS" class="w-10 h-10" />
        </div>
      </div>
    </div>

    <div class="divider"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-x-20">
      <div>
        <h3 class="text-lg font-semibold mb-3">Backend</h3>
        <div class="grid grid-cols-4 gap-4">
          <img src="/skills/php.svg" alt="PHP" title="PHP" class="w-10 h-10" />
          <img src="/skills/laravel.svg" alt="Laravel" title="Laravel" class="w-10 h-10" />
          <img src="/skills/dotnet.svg" alt=".NET" title=".NET" class="w-10 h-10" />
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-3">Database</h3>
        <div class="grid grid-cols-4 gap-4">
          <img src="/skills/mysql.svg" alt="MySQL" title="MySQL" class="w-10 h-10" />
          <img src="/skills/Microsoft_SQL_Server_2025_icon.svg" alt="SQL Server" title="SQL Server" class="w-10 h-10" />
        </div>
      </div>
    </div>

    <div class="divider"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-x-20">
      <div>
        <h3 class="text-lg font-semibold mb-3">DevOps & Tools</h3>
        <div class="grid grid-cols-4 gap-4">
          <img src="/skills/git.svg" alt="Git" title="Git" class="w-10 h-10" />
          <img src="/skills/github.svg" alt="GitHub" title="GitHub" class="w-10 h-10" />
          <img src="/skills/linux.svg" alt="Linux" title="Linux" class="w-10 h-10" />
          <img src="/skills/postman.svg" alt="Postman" title="Postman" class="w-10 h-10" />
          <img src="/skills/rest-api-icon.svg" alt="REST APIs" title="REST APIs" class="w-10 h-10" />
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-3">Modern Stack</h3>
        <div class="grid grid-cols-4 gap-4">
          <img src="/skills/tanstack.svg" alt="TanStack Start" title="TanStack Start" class="w-10 h-10" />
          <img src="/skills/resend.svg" alt="Resend" title="Resend" class="w-10 h-10" />
        </div>
      </div>
    </div>

    <div class="divider"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-x-20">
      <div>
        <h3 class="text-lg font-semibold mb-3">Systems</h3>
        <div class="grid grid-cols-4 gap-4">
          <img src="/skills/erp-icon.svg" alt="ERP Systems" title="ERP Systems" class="w-10 h-10" />
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-3">AI Tools</h3>
        <div class="grid grid-cols-4 gap-4">
          <img src="/skills/opencode-logo-light.svg" alt="OpenCode" title="OpenCode" class="w-10 h-10" />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
